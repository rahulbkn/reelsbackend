PORT=3000

# The ONLY line you change to migrate storage backends.
# telegram | r2 | supabase | s3 | local
STORAGE_PROVIDER=telegram

# Public URL this server is reachable at — used to build /stream URLs.
# Never expose api.telegram.org URLs or the bot token to clients.
PUBLIC_BASE_URL=http://localhost:3000

# --- Telegram storage provider (required when STORAGE_PROVIDER=telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- R2 (required when STORAGE_PROVIDER=r2) --------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=

# --- Supabase Storage (required when STORAGE_PROVIDER=supabase) ------------
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_BUCKET=

# --- S3-compatible (required when STORAGE_PROVIDER=s3) ---------------------
# S3_ENDPOINT=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=

# --- Local disk (required when STORAGE_PROVIDER=local) ---------------------
# LOCAL_STORAGE_ROOT=./data/local-storage
